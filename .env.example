PORT=3050

# Server-only — used during SSR (e.g. internal Docker network URL)
NUXT_SERVER_API_BASE_URL=http://localhost:3050

# Public — used in the browser
NUXT_PUBLIC_CLIENT_API_BASE_URL=http://localhost:3050

# CDN or storage base for resolving relative media paths from the API
NUXT_PUBLIC_ASSETS_BASE_URL=

# Sent as X-Version header on every API request
NUXT_PUBLIC_API_VERSION=1.0

# Optional admin panel URL
NUXT_PUBLIC_DASHBOARD_URL=

# Google Analytics (optional — not wired by default)
# NUXT_PUBLIC_GTAG_ID=G-XXXXXXXXXX
